@startuml
hide circle
skinparam classAttributeIconSize 0

class User {
  +username: String
  +role: String
  +status: String
  +violationCount: Number
  +lastViolationAt: Date
}

class ForumPost {
  +author: String
  +category: String
  +title: String
  +content: String
  +isDeleted: Boolean
  +deletedAt: Date
  +deletedBy: String
  +deletionReason: String
}

class ForumComment {
  +postId: ObjectId
  +author: String
  +text: String
  +isDeleted: Boolean
  +deletedAt: Date
  +deletedBy: String
  +deletionReason: String
}

class VideoLink {
  +category: String
  +url: String
  +addedBy: String
}

class ModerationReport {
  +targetType: String
  +targetId: String
  +targetAuthor: String
  +content: String
  +reporter: String
  +decision: String
  +reason: String
  +confidence: Number
}

class AuthController
class ForumController
class VideoController
class ModerationController
class UserController
class ChatController
class HealthController

class ModerationService
class TokenUtils
class PasswordUtils
class UserUtils
class YoutubeUtils

ForumComment --> ForumPost : postId
ModerationReport ..> ForumPost : targetId (post)
ModerationReport ..> ForumComment : targetId (comment)

AuthController ..> User
AuthController ..> TokenUtils
AuthController ..> PasswordUtils
AuthController ..> UserUtils

ForumController ..> ForumPost
ForumController ..> ForumComment

VideoController ..> VideoLink
VideoController ..> YoutubeUtils

ModerationController ..> ModerationReport
ModerationController ..> ForumPost
ModerationController ..> ForumComment
ModerationController ..> User
ModerationController ..> ModerationService

UserController ..> User

ChatController ..> ModerationService : uses Gemini client

@enduml
