@startuml
start
:User submits report;
:Validate request;
if (Data valid?) then (yes)
  :Call ModerationService.evaluateModeration;
  :Create ModerationReport;
  if (Decision == delete?) then (yes)
    :Mark post/comment as deleted;
    if (Target author exists?) then (yes)
      :Increment violationCount;
      if (violationCount >= 3?) then (yes)
        :Set status = suspended;
      else (no)
        :Keep status;
      endif
    else (no)
      :Skip user update;
    endif
  else (no)
    :Keep content;
  endif
  :Return response to user;
else (no)
  :Return 400 validation error;
endif
stop
@enduml
