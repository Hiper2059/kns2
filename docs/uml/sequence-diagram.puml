@startuml
actor User
participant "ModerationController" as MC
participant "ModerationService" as MS
participant "Gemini API" as Gemini
participant "ModerationReport" as Report
participant "ForumPost/ForumComment" as Content
participant "User Model" as UserModel

User -> MC: POST /moderation/report
MC -> MC: validate input
MC -> MS: evaluateModeration(content)
MS -> Gemini: generateContent(prompt)
Gemini --> MS: decision, reason, confidence
MS --> MC: moderation result
MC -> Report: create(report)

alt decision == delete
  MC -> Content: mark isDeleted = true
  MC -> UserModel: increment violationCount
  MC -> UserModel: update status if needed
else decision == keep
  MC -> MC: no content change
end

MC --> User: response
@enduml
