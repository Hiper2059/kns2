@startuml
left to right direction
actor "Guest" as Guest
actor "Student" as Student
actor "Teacher" as Teacher
actor "Admin/Moderator" as Admin
actor "External Service" as External

package "Authentication" {
  usecase "Register" as UC_Register
  usecase "Login" as UC_Login
  usecase "Refresh Token" as UC_Refresh
}

package "Courses & Lessons" {
  usecase "Browse Courses" as UC_Browse
  usecase "View Course Details" as UC_ViewCourse
  usecase "Create/Manage Course" as UC_ManageCourse
  usecase "Create/Manage Lesson" as UC_ManageLesson
}

package "Learning" {
  usecase "Enroll in Course" as UC_Enroll
  usecase "Mark Lesson Complete" as UC_CompleteLesson
  usecase "View Progress / Evaluation" as UC_Progress
}

package "Community" {
  usecase "Create Forum Post" as UC_Post
  usecase "Comment on Post" as UC_Comment
  usecase "Real-time Chat" as UC_Chat
}

package "Content & Moderation" {
  usecase "Upload Assets" as UC_Upload
  usecase "Add Video Link" as UC_AddVideo
  usecase "Report Content" as UC_Report
  usecase "Moderation Decision" as UC_Moderate
}

package "Ops" {
  usecase "Health Check" as UC_Health
}

' Actors -> Use Cases
Guest --> UC_Register
Guest --> UC_Login
Student --> UC_Browse
Student --> UC_ViewCourse
Student --> UC_Enroll
Student --> UC_CompleteLesson
Student --> UC_Progress
Teacher --> UC_ManageCourse
Teacher --> UC_ManageLesson
Teacher --> UC_Progress
Teacher --> UC_AddVideo
Admin --> UC_Moderate
Admin --> UC_Report
Student --> UC_Post
Student --> UC_Comment
Teacher --> UC_Post
Guest --> UC_Browse
Student --> UC_Chat
External --> UC_Upload
External --> UC_AddVideo

' Relationships
UC_ManageCourse ..> UC_ManageLesson : includes
UC_Enroll ..> UC_Progress : updates
UC_Report ..> UC_Moderate : triggers
UC_Upload ..> UC_AddVideo : supports

@enduml
